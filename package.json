{
  "name": "flowkit",
  "private": true,
  "version": "0.0.1-beta.0",
  "description": "Browser-based UI prototyping platform for multi-screen, flow-based interactive previews.",
  "license": "MIT",
  "author": "Rahil Kothari <Rahilkothari5@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/rahil-avj/flowkit-app.git"
  },
  "keywords": [
    "flowkit",
    "prototyping",
    "ui-prototyping",
    "flow",
    "wireframe",
    "react",
    "vite",
    "design-tool"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "flowkit": "scripts/flowkit.js"
  },
  "files": [
    "scripts/",
    "src/",
    "dist/lib/",
    "dist/types/",
    "docs/",
    "./index.html",
    "!scripts/tests/",
    "!scripts/builders/format.mjs",
    "!scripts/dev/"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/core/config/index.d.ts",
      "import": "./dist/lib/index.js"
    },
    "./vite": {
      "types": "./scripts/helpers/vite-plugin.d.ts",
      "import": "./scripts/helpers/vite-plugin.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/flowkit.js check:flowplans",
    "build": "tsc -b && vite build",
    "build:standalone": "tsc -b && vite build && node scripts/builders/inline.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "build:lib": "tsc -p tsconfig.build.json && vite build --config vite.lib.config.ts",
    "docs:api": "typedoc",
    "preview": "vite preview",
    "format": "node scripts/builders/format.mjs",
    "format:check": "prettier --check .",
    "test:workspace": "node --test --test-concurrency=1 scripts/tests/workspace-registry.test.js scripts/tests/workspace-cli.test.js scripts/tests/stub-fallback.test.js scripts/tests/scaffold-consistency.test.js scripts/tests/checks-rules.test.js scripts/tests/check-cli.test.js scripts/tests/kebab-normalize.test.js scripts/tests/flowplan-steps-cli.test.js"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^8.62.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esbuild": "^0.28.1",
    "lucide-react": "^1.17.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-tailwindcss": "^4.0.4",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typedoc": "^0.28.20",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.9"
  }
}
